    "brazilian",
    "portuguese"
  ],
  "author": "BRZ Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/DornelassDev/brz"
  },
  "homepage": "https://DornelassDev.github.io/brz/",
  "engines": {
    "node": ">=16.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "files": [
    "bin/",
    "lib/",
    "java/target/brz.jar",
