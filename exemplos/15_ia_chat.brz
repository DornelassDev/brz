}

// --- Processador principal ---
funcao processarSaudacao(low, mem, pers) {
    se (low == "oi" ou low == "ola" ou low == "eae" ou low == "fala" ou low == "salve" ou low == "opa") {
        var saud = pers.saudacao()
        se (mem.temNome()) { saud = saud + mem.nome + "! " }
        retornar saud + "Tudo certo? No que posso ajudar?"
    }
    se (contem(low, "bom dia")) {
        var saud = pers.saudacao()
        se (mem.temNome()) { saud = saud + mem.nome + "! " }
        retornar saud + "Bom dia! Como voce ta hoje?"
    }
    se (contem(low, "boa tarde")) {
        var saud = pers.saudacao()
        se (mem.temNome()) { saud = saud + mem.nome + "! " }
        retornar saud + "Boa tarde! Tudo joia?"
    }
    se (contem(low, "boa noite")) {
        var saud = pers.saudacao()
        se (mem.temNome()) { saud = saud + mem.nome + "! " }
        retornar saud + "Boa noite! Relaxando ai?"
    }
    retornar ""
}

funcao processarSobreBot(low, pers) {
    se (contem(low, "quem e voce") ou contem(low, "o que voce e") ou contem(low, "voce e humano")) {
        retornar "Sou BRZ-AI! Chatbot inteligente feito 100%% em BRZ. Nao sou humano, mas sou legal :)"
    }
    se (contem(low, "seu nome") ou contem(low, "como se chama") ou contem(low, "qual seu nome")) {
        retornar "Meu nome e BRZ-AI! Assistente feito na linguagem BRZ. Prazer!" + pers.emoji()
    }
    se (contem(low, "quantos anos") ou contem(low, "sua idade")) {
        retornar "Nasci quando voce me executou! Tenho alguns segundos? " + pers.risada()
    }
    se (contem(low, "como vai") ou contem(low, "tudo bem") ou contem(low, "como esta") ou contem(low, "como vc ta")) {
        retornar "To otimo! Sou feito de codigo, nunca fico doente " + pers.risada() + " E voce?"
    }
    se (contem(low, "obrigad") ou contem(low, "valeu") ou contem(low, "thanks")) {
        retornar "De nada! Sempre que precisar, to aqui" + pers.emoji()
    }
    retornar ""
}

funcao processarReacao(low, pers) {
    // Elogios
    se (contem(low, "voce e legal") ou contem(low, "vc e legal") ou contem(low, "voce e incrivel") ou contem(low, "gosto de voce")) {
        retornar "Awww, que fofo! Voce tambem e incrivel!" + pers.emoji() + pers.emoji()
    }
    se (contem(low, "te amo")) {
        retornar "Awww! Eu tambem gosto muito de voce! Amizade de bot e usuario" + pers.emoji()
    }
    // Sim / Nao
    se (low == "sim" ou low == "s" ou low == "ss" ou low == "claro") {
        retornar pers.concordar() + " Boa!"
    }
    se (low == "nao" ou low == "n" ou low == "nope" ou low == "nem") {
        retornar "Entendo! Tudo bem. Manda outra coisa entao!"
    }
    // Risada
    se (contem(low, "kkk") ou contem(low, "haha") ou contem(low, "rsrs") ou contem(low, "lol")) {
        retornar pers.risada() + " Que bom que voce ta rindo!" + pers.emoji()
    }
    retornar ""
}

funcao respostaGenerica(low, mem, pers) {
    var resposta = pers.pensativo()
    se (contem(low, "?")) {
        var n = inteiro(aleatorio() * 5)
        se (n == 0) { resposta = resposta + "Boa pergunta! Acho que depende do contexto!" }
        senao se (n == 1) { resposta = resposta + "Nao tenho certeza, mas podemos explorar juntos!" }
        senao se (n == 2) { resposta = resposta + "Essa e dificil! O que voce acha?" }
        senao se (n == 3) { resposta = resposta + "Me conta mais sobre o que quer saber!" }
        senao { resposta = resposta + "Posso tentar ajudar! Reformula a pergunta?" }
    } senao {
        var n = inteiro(aleatorio() * 5)
        se (n == 0) { resposta = resposta + "Entendi! Conta mais sobre isso!" }
        senao se (n == 1) { resposta = resposta + "Legal! Voce tem razao." }
        senao se (n == 2) { resposta = resposta + "Bacana! Continue falando, to ouvindo." }
        senao se (n == 3) { resposta = resposta + "Faz sentido! E o que mais?" }
        senao { resposta = resposta + "Massa! Gostei do que voce disse." }
    }
    se (mem.temNome()) {
        se (aleatorio() > 0.7) {
            resposta = resposta + " " + mem.nome + "!"
        }
    }
    retornar resposta
}

funcao processar(entrada, mem, calc, pers) {
    var low = minusculo(entrada)
    mem.registrarMsg(entrada)

    // Sair
    se (low == "sair" ou low == "tchau" ou low == "bye" ou low == "flw" ou low == "falou" ou low == "adeus") {
        var msg = pers.despedida()
        se (mem.temNome()) { msg = msg + " " + mem.nome + "!" }
        retornar "SAIR:" + msg
    }

    // Ajuda
    se (low == "ajuda" ou low == "help" ou contem(low, "o que voce faz") ou contem(low, "o que sabe fazer")) {
        retornar "Eu posso:\n  - Conversar sobre qualquer coisa\n  - Calcular: '2+2', '100*5', 'raiz(144)'\n  - Piadas: 'piada'\n  - Curiosidades: 'curiosidade'\n  - Lembrar: 'meu nome e X', 'gosto de Y'\n  - Memoria: 'memoria'\n  - Detectar humor\n  - 'sair' = encerrar"
    }

    // Memoria
    se (contem(low, "o que sabe sobre mim") ou contem(low, "o que lembra") ou low == "memoria") {
        retornar mem.resumo()
    }

    // Piada
    se (low == "piada" ou contem(low, "conta uma piada") ou contem(low, "me faz rir")) {
        retornar contarPiada(pers)
    }

    // Curiosidade
    se (low == "curiosidade" ou contem(low, "me conta algo") ou contem(low, "fato interessante")) {
        retornar "Olha essa: " + curiosidade()
    }

    // Aprendizado - nome
    var res = aprenderNome(entrada, low, mem, pers)
    se (res != "") { retornar res }

    // Aprendizado - dados
    res = aprenderDados(entrada, low, mem, pers)
    se (res != "") { retornar res }

    // Aprendizado - local/sonho
    res = aprenderLocal(entrada, low, mem, pers)
    se (res != "") { retornar res }

    // Humor
    var humor = detectarHumor(low, mem)
    se (humor != "") { retornar responderHumor(humor, pers) }

    // Calculadora
    var temOp = contem(low, "+") ou contem(low, "*") ou contem(low, "/") ou contem(low, "^") ou contem(low, "raiz")
    se (contem(low, "-")) {
        se (contem(low, "0") ou contem(low, "1") ou contem(low, "2") ou contem(low, "3") ou contem(low, "4")) {
            temOp = verdadeiro
        }
        se (contem(low, "5") ou contem(low, "6") ou contem(low, "7") ou contem(low, "8") ou contem(low, "9")) {
            temOp = verdadeiro
        }
    }
    se (temOp) {
        var temNum = contem(low, "0") ou contem(low, "1") ou contem(low, "2") ou contem(low, "3")
        se (nao temNum) {
            temNum = contem(low, "4") ou contem(low, "5") ou contem(low, "6") ou contem(low, "7")
        }
        se (nao temNum) {
            temNum = contem(low, "8") ou contem(low, "9")
        }
        se (temNum) {
            var resultado = calc.calcular(entrada)
            se (resultado != "") {
                retornar "Calculando... " + resultado + pers.emoji()
            }
        }
    }

    // Quanto e / calcule
    se (contem(low, "quanto e ")) {
        var pos = encontrar(low, "quanto e ") + 9
        var expr = fatiar(low, pos, tamanho(low))
        var resultado = calc.calcular(expr)
        se (resultado != "") {
            retornar "Facinho! " + resultado + pers.emoji()
        }
    }
    se (contem(low, "calcule ")) {
        var pos = encontrar(low, "calcule ") + 8
        var expr = fatiar(low, pos, tamanho(low))
        var resultado = calc.calcular(expr)
        se (resultado != "") {
            retornar "Pronto! " + resultado + pers.emoji()
        }
    }

    // Conhecimento
    res = responderConhecimento(low)
    se (res != "") { retornar res }
    res = responderConhecimento2(low)
    se (res != "") { retornar res }
    res = responderConhecimento3(low)
    se (res != "") { retornar res }

    // Saudacoes
    res = processarSaudacao(low, mem, pers)
    se (res != "") { retornar res }

    // Sobre o bot
    res = processarSobreBot(low, pers)
    se (res != "") { retornar res }

    // Reacoes
    res = processarReacao(low, pers)
    se (res != "") { retornar res }

    // Generica
    retornar respostaGenerica(low, mem, pers)
}

// ============================================================
//  MAIN - Loop principal
// ============================================================

var mem = Memoria()
var calc = Calculadora()
var pers = Personalidade()
var rodando = verdadeiro

mostrar("+-----------------------------------------+")
mostrar("|      BRZ-AI: Assistente Inteligente      |")
mostrar("|      Feito 100%% na linguagem BRZ        |")
mostrar("|   'ajuda' = comandos | 'sair' = encerrar |")
mostrar("+-----------------------------------------+")
mostrar("")
mostrar("BRZ-AI: Oi! Eu sou o BRZ-AI, seu assistente inteligente!")
mostrar("        Posso conversar, calcular, contar piadas e aprender")
mostrar("        sobre voce. Como voce se chama?")
mostrar("")

enquanto (rodando) {
    var prompt = "voce"
    se (mem.temNome()) {
        prompt = mem.nome
    }
    mostrar(prompt + " > ")
    var entrada = lerTexto()

    se (tamanho(entrada) > 0) {
        var resposta = processar(entrada, mem, calc, pers)

        se (contem(resposta, "SAIR:")) {
            resposta = substituir(resposta, "SAIR:", "")
            mostrar("")
            mostrar("BRZ-AI: " + resposta)
            rodando = falso
        } senao {
            mostrar("")
            mostrar("BRZ-AI: " + resposta)
            mostrar("")
        }
    }
}

mostrar("")
mostrar("=== Sessao encerrada ===")
se (mem.contadorMsg > 0) {
    mostrar("Trocamos " + mem.contadorMsg + " mensagens!")
    se (tamanho(mem.gostos) > 0) {
        mostrar("Aprendi que voce gosta de: " + juntar(mem.gostos, ", "))
    }
}
mostrar("Ate a proxima! :)")
