    }
    se (contem(low, "escola") ou contem(low, "estud") ou contem(low, "faculdade")) {
        retornar "Estudar e importante! Conhecimento e poder. Programacao e superpoder!"
    }
    se (contem(low, "trabalho") ou contem(low, "emprego") ou contem(low, "trampo")) {
        retornar "Trabalho e parte da vida! Mas descanse tambem. Burnout nao e brincadeira!"
    }
