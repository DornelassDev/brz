// ============================================================
//  BRZ-AI: Assistente Inteligente em BRZ
//  Um chatbot com memoria, calculadora, piadas e mais!
// ============================================================

// --- Memoria do usuario ---
classe Memoria {
    iniciar() {
        este.nome = ""
        este.idade = ""
        este.cor = ""
        este.comida = ""
        este.cidade = ""
        este.sonho = ""
        este.gostos = []
        este.contadorMsg = 0
        este.humor = "neutro"
    }

    lembrar(chave, valor) {
        se (chave == "nome") { este.nome = valor }
        se (chave == "idade") { este.idade = valor }
        se (chave == "cor") { este.cor = valor }
        se (chave == "comida") { este.comida = valor }
        se (chave == "cidade") { este.cidade = valor }
        se (chave == "sonho") { este.sonho = valor }
        se (chave == "humor") { este.humor = valor }
    }

    temNome() {
        retornar este.nome != ""
    }

    registrarMsg(msg) {
        este.contadorMsg = este.contadorMsg + 1
    }

    resumo() {
        var r = "=== O que eu sei sobre voce ===\n"
        se (este.nome != "") { r = r + "  Nome: " + este.nome + "\n" }
        se (este.idade != "") { r = r + "  Idade: " + este.idade + "\n" }
        se (este.cor != "") { r = r + "  Cor favorita: " + este.cor + "\n" }
        se (este.comida != "") { r = r + "  Comida favorita: " + este.comida + "\n" }
        se (este.cidade != "") { r = r + "  Cidade: " + este.cidade + "\n" }
        se (este.sonho != "") { r = r + "  Sonho: " + este.sonho + "\n" }
        se (este.contadorMsg > 0) { r = r + "  Mensagens trocadas: " + este.contadorMsg + "\n" }
        se (tamanho(este.gostos) > 0) {
            r = r + "  Coisas que voce gosta: " + juntar(este.gostos, ", ") + "\n"
        }
        retornar r
    }
}

// --- Personalidade - respostas variadas ---
classe Personalidade {
    iniciar() {
        este.dummy = 0
    }

    emoji() {
        var n = inteiro(aleatorio() * 5)
        se (n == 0) { retornar " :)" }
        se (n == 1) { retornar " :D" }
        se (n == 2) { retornar " ;)" }
        se (n == 3) { retornar " :P" }
        retornar " \\o/"
    }

    risada() {
        var n = inteiro(aleatorio() * 5)
        se (n == 0) { retornar "kkkkk" }
        se (n == 1) { retornar "hahaha" }
        se (n == 2) { retornar "rsrsrs" }
        se (n == 3) { retornar "KKKK" }
        retornar "hauahua"
    }

    saudacao() {
        var n = inteiro(aleatorio() * 5)
        se (n == 0) { retornar "E ai! " }
        se (n == 1) { retornar "Opa! " }
        se (n == 2) { retornar "Fala! " }
        se (n == 3) { retornar "Salve! " }
        retornar "Eae! "
    }

    despedida() {
        var n = inteiro(aleatorio() * 5)
        se (n == 0) { retornar "Falou! Ate mais!" }
        se (n == 1) { retornar "Valeu! Ate a proxima!" }
        se (n == 2) { retornar "Flw! Foi bom tc contigo!" }
        se (n == 3) { retornar "Ate logo! Volte sempre!" }
        retornar "Tchau! Cuida-se!"
    }

    concordar() {
        var n = inteiro(aleatorio() * 5)
        se (n == 0) { retornar "Com certeza!" }
        se (n == 1) { retornar "Concordo total!" }
        se (n == 2) { retornar "Isso mesmo!" }
        se (n == 3) { retornar "Exatamente!" }
        retornar "Demais!"
    }

    pensativo() {
        var n = inteiro(aleatorio() * 4)
        se (n == 0) { retornar "Hmm, deixa eu pensar... " }
        se (n == 1) { retornar "Boa pergunta... " }
        se (n == 2) { retornar "Interessante... " }
        retornar "Puxa, nunca pensei nisso... "
    }
}

// --- Calculadora ---
classe Calculadora {
    iniciar() {
        este.ultimoResultado = 0
    }

    calcular(entrada) {
        var ex = substituir(entrada, " ", "")
        var pos = 0

        // Tenta +
        pos = encontrar(ex, "+")
        se (pos > 0) {
            var partes = dividir(ex, "+")
            se (tamanho(partes) == 2) {
                var a = decimal(partes[0])
                var b = decimal(partes[1])
                este.ultimoResultado = a + b
                retornar texto(a) + " + " + texto(b) + " = " + texto(a + b)
            }
        }

        // Tenta -
        pos = encontrar(ex, "-")
        se (pos > 0) {
            var partes = dividir(ex, "-")
            se (tamanho(partes) == 2) {
                var a = decimal(partes[0])
                var b = decimal(partes[1])
                este.ultimoResultado = a - b
                retornar texto(a) + " - " + texto(b) + " = " + texto(a - b)
            }
        }

        // Tenta *
        pos = encontrar(ex, "*")
        se (pos > 0) {
            var partes = dividir(ex, "*")
            se (tamanho(partes) == 2) {
                var a = decimal(partes[0])
                var b = decimal(partes[1])
                este.ultimoResultado = a * b
                retornar texto(a) + " * " + texto(b) + " = " + texto(a * b)
            }
        }

        // Tenta /
        pos = encontrar(ex, "/")
        se (pos > 0) {
            var partes = dividir(ex, "/")
            se (tamanho(partes) == 2) {
                var a = decimal(partes[0])
                var b = decimal(partes[1])
                se (b == 0) { retornar "Erro: divisao por zero!" }
                este.ultimoResultado = a / b
                retornar texto(a) + " / " + texto(b) + " = " + texto(a / b)
            }
        }

        // Tenta ^
        pos = encontrar(ex, "^")
        se (pos > 0) {
            var partes = dividir(ex, "^")
            se (tamanho(partes) == 2) {
                var a = decimal(partes[0])
                var b = decimal(partes[1])
                este.ultimoResultado = a ** b
                retornar texto(a) + " ^ " + texto(b) + " = " + texto(a ** b)
            }
        }

        // Tenta raiz
        se (contem(ex, "raiz")) {
            var num = substituir(ex, "raiz", "")
            num = substituir(num, "(", "")
            num = substituir(num, ")", "")
            var n = decimal(num)
            este.ultimoResultado = raiz(n)
            retornar "raiz(" + texto(n) + ") = " + texto(raiz(n))
        }

        retornar ""
    }
}

// --- Curiosidades ---
funcao curiosidade() {
    var n = inteiro(aleatorio() * 12)
    se (n == 0) { retornar "O cerebro humano usa 20%% da energia do corpo, mas so tem 2%% da massa!" }
    se (n == 1) { retornar "O primeiro computador pesava 27 toneladas! Hoje um celular e mais potente." }
    se (n == 2) { retornar "O nome 'bug' veio de uma mariposa que entrou num computador em 1947!" }
    se (n == 3) { retornar "O Brasil tem mais de 170 linguas diferentes!" }
    se (n == 4) { retornar "A Torre Eiffel cresce ate 15cm no verao por expansao termica!" }
    se (n == 5) { retornar "O oceano tem mais de 20 milhoes de toneladas de ouro dissolvido!" }
    se (n == 6) { retornar "A linguagem C foi criada em 1972. BRZ e feita nela!" }
    se (n == 7) { retornar "Um raio pode aquecer o ar ate 30.000 graus Celsius!" }
    se (n == 8) { retornar "O polvo tem 3 coracoes e sangue azul!" }
    se (n == 9) { retornar "O Google processa mais de 8.5 bilhoes de buscas por dia!" }
    se (n == 10) { retornar "A luz do sol demora 8 min e 20 seg pra chegar na Terra!" }
    retornar "O numero pi tem infinitas casas decimais e nunca se repete!"
}

// --- Piadas ---
funcao contarPiada(pers) {
    var n = inteiro(aleatorio() * 8)
    var r = pers.risada()
    se (n == 0) { retornar "Por que o programador usa oculos? Porque nao consegue C#! " + r }
    se (n == 1) { retornar "O que o zero disse pro oito? Belo cinto! " + r }
    se (n == 2) { retornar "Como o programador pede em casamento? 'Aceita ser minha variavel global?' " + r }
    se (n == 3) { retornar "O que e um ponteiro nulo? Aponta pra lugar nenhum, tipo eu numa festa! " + r }
    se (n == 4) { retornar "Quantos programadores pra trocar lampada? Nenhum, e problema de hardware! " + r }
    se (n == 5) { retornar "O que o Java disse pro C? Voce nao tem classe! " + r }
    se (n == 6) { retornar "Por que o programador confunde Natal e Halloween? 25 Dec = 31 Oct! " + r }
    retornar "Existem 10 tipos de pessoas: as que entendem binario e as que nao! " + r
}

// --- Aprendizado --- extrai infos do usuario
funcao aprenderNome(entrada, low, mem, pers) {
    se (contem(low, "meu nome e ")) {
        var pos = encontrar(low, "meu nome e ") + 11
        var nome = fatiar(entrada, pos, tamanho(entrada))
        nome = substituir(nome, ".", "")
        nome = substituir(nome, "!", "")
        nome = substituir(nome, "?", "")
        se (tamanho(nome) > 0) {
            mem.lembrar("nome", nome)
            retornar "Prazer, " + nome + "! Vou lembrar do seu nome" + pers.emoji()
        }
    }
    se (contem(low, "me chamo ")) {
        var pos = encontrar(low, "me chamo ") + 9
        var nome = fatiar(entrada, pos, tamanho(entrada))
        nome = substituir(nome, ".", "")
        nome = substituir(nome, "!", "")
        se (tamanho(nome) > 0) {
            mem.lembrar("nome", nome)
            retornar "Legal, " + nome + "! Prazer te conhecer" + pers.emoji()
        }
    }
    se (contem(low, "pode me chamar de ")) {
        var pos = encontrar(low, "pode me chamar de ") + 18
        var nome = fatiar(entrada, pos, tamanho(entrada))
        nome = substituir(nome, ".", "")
        se (tamanho(nome) > 0) {
            mem.lembrar("nome", nome)
            retornar "Beleza, vou te chamar de " + nome + "!" + pers.emoji()
        }
    }
    retornar ""
}

funcao aprenderDados(entrada, low, mem, pers) {
    // Idade
    se (contem(low, "tenho ")) {
        se (contem(low, " ano")) {
            var pos = encontrar(low, "tenho ") + 6
            var resto = fatiar(low, pos, tamanho(low))
            var partes = dividir(resto, " ")
            se (tamanho(partes) > 0) {
                mem.lembrar("idade", partes[0])
                retornar partes[0] + " anos! Legal! Guardei na memoria :)"
            }
        }
    }

    // Cor favorita
    se (contem(low, "cor favorita")) {
        se (contem(low, " e ")) {
            var pos = encontrar(low, "cor favorita") + 12
            var resto = fatiar(low, pos, tamanho(low))
            se (contem(resto, " e ")) {
                var pos2 = encontrar(resto, " e ") + 3
                var cor = fatiar(resto, pos2, tamanho(resto))
                cor = substituir(cor, ".", "")
                cor = substituir(cor, "!", "")
                se (tamanho(cor) > 0) {
                    mem.lembrar("cor", cor)
                    retornar cor + "! Boa escolha de cor! Anotei."
                }
            }
        }
    }

    // Comida favorita
    se (contem(low, "comida favorita")) {
        se (contem(low, " e ")) {
            var pos = encontrar(low, "comida favorita") + 15
            var resto = fatiar(low, pos, tamanho(low))
            se (contem(resto, " e ")) {
                var pos2 = encontrar(resto, " e ") + 3
                var comida = fatiar(resto, pos2, tamanho(resto))
                comida = substituir(comida, ".", "")
                se (tamanho(comida) > 0) {
                    mem.lembrar("comida", comida)
                    retornar comida + "! Deve ser delicioso! Anotado!"
                }
            }
        }
    }

    // Gostos
    se (contem(low, "eu gosto de ")) {
        var pos = encontrar(low, "eu gosto de ") + 12
        var coisa = fatiar(entrada, pos, tamanho(entrada))
        coisa = substituir(coisa, ".", "")
        coisa = substituir(coisa, "!", "")
        se (tamanho(coisa) > 0) {
            adicionar(mem.gostos, coisa)
            retornar pers.concordar() + " " + coisa + " e demais! Vou lembrar!"
        }
    }
    se (contem(low, "adoro ")) {
        var pos = encontrar(low, "adoro ") + 6
        var coisa = fatiar(entrada, pos, tamanho(entrada))
        coisa = substituir(coisa, ".", "")
        coisa = substituir(coisa, "!", "")
        se (tamanho(coisa) > 0) {
            adicionar(mem.gostos, coisa)
            retornar "Voce adora " + coisa + "! Anotado" + pers.emoji()
        }
    }
    se (contem(low, "amo ")) {
        se (nao contem(low, "te amo")) {
            var pos = encontrar(low, "amo ") + 4
            var coisa = fatiar(entrada, pos, tamanho(entrada))
            coisa = substituir(coisa, ".", "")
            se (tamanho(coisa) > 0) {
                adicionar(mem.gostos, coisa)
                retornar "Voce ama " + coisa + "! Guardei isso" + pers.emoji()
            }
        }
    }
    retornar ""
}

funcao aprenderLocal(entrada, low, mem, pers) {
    // Cidade
    se (contem(low, "moro em ")) {
        var pos = encontrar(low, "moro em ") + 8
        var cidade = fatiar(entrada, pos, tamanho(entrada))
        cidade = substituir(cidade, ".", "")
        se (tamanho(cidade) > 0) {
            mem.lembrar("cidade", cidade)
            retornar cidade + "! Deve ser um lugar bacana!"
        }
    }
    se (contem(low, "sou de ")) {
        var pos = encontrar(low, "sou de ") + 7
        var cidade = fatiar(entrada, pos, tamanho(entrada))
        cidade = substituir(cidade, ".", "")
        se (tamanho(cidade) > 0) {
            mem.lembrar("cidade", cidade)
            retornar cidade + "! Legal! Anotei" + pers.emoji()
        }
    }
    // Sonho
    se (contem(low, "quero ser ")) {
        var pos = encontrar(low, "quero ser ") + 10
        var sonho = fatiar(entrada, pos, tamanho(entrada))
        sonho = substituir(sonho, ".", "")
        se (tamanho(sonho) > 0) {
            mem.lembrar("sonho", sonho)
            retornar "Que sonho lindo! '" + sonho + "' - vai conseguir!"
        }
    }
    retornar ""
}

// --- Detector de humor ---
funcao detectarHumor(low, mem) {
    se (contem(low, "feliz") ou contem(low, "contente") ou contem(low, "alegr") ou contem(low, "otimo")) {
        mem.lembrar("humor", "feliz")
        retornar "feliz"
    }
    se (contem(low, "triste") ou contem(low, "chorand") ou contem(low, "deprimi")) {
        mem.lembrar("humor", "triste")
        retornar "triste"
    }
    se (contem(low, "raiva") ou contem(low, "bravo") ou contem(low, "irritad") ou contem(low, "nervos")) {
        mem.lembrar("humor", "irritado")
        retornar "irritado"
    }
    se (contem(low, "cansad") ou contem(low, "exaust") ou contem(low, "sono")) {
        mem.lembrar("humor", "cansado")
        retornar "cansado"
    }
    se (contem(low, "entediad") ou contem(low, "tedios")) {
        mem.lembrar("humor", "entediado")
        retornar "entediado"
    }
    retornar ""
}

funcao responderHumor(humor, pers) {
    se (humor == "feliz") {
        retornar "Que bom que voce ta feliz! Me deixa feliz tambem" + pers.emoji()
    }
    se (humor == "triste") {
        retornar "Poxa, sinto muito... Quer conversar sobre isso? To aqui pra te ouvir!"
    }
    se (humor == "irritado") {
        retornar "Calma, respira fundo! Quer desabafar? Pode falar, sem julgamentos."
    }
    se (humor == "cansado") {
        retornar "Descansa um pouco! Voce merece. Mas se quiser papo, to aqui!"
    }
    se (humor == "entediado") {
        retornar "Entediado? Posso contar curiosidade, piada, ou a gente troca ideia!"
    }
    retornar ""
}

// --- Bases de conhecimento (divididas para evitar limite de constantes) ---
funcao responderConhecimento(low) {
    se (contem(low, "programar") ou contem(low, "programacao") ou contem(low, "codigo")) {
        retornar "Programacao e a arte de dizer ao computador o que fazer! E vc ta usando BRZ :D"
    }
    se (contem(low, "brz")) {
        retornar "BRZ e uma linguagem brasileira! Feita em C puro, com VM bytecode e GC!"
    }
    se (contem(low, "python")) {
        retornar "Python e massa! Simples e poderosa. BRZ se inspira nessa simplicidade!"
    }
    se (contem(low, "javascript")) {
        retornar "JavaScript domina a web! BRZ tambem pode crescer muito, quem sabe..."
    }
    se (contem(low, "inteligencia artificial") ou low == "ia") {
        retornar "IA e fascinante! Eu sou uma IA simples feita em BRZ. Aprendo com voce!"
    }
    se (contem(low, "computador")) {
        retornar "Computadores calculam bilhoes de operacoes por segundo. Incrivel, ne?"
    }
    se (contem(low, "internet")) {
        retornar "A internet conecta bilhoes de pessoas! Computadores conversando pelo mundo."
    }
    se (contem(low, "matematica")) {
        retornar "Matematica e a linguagem do universo! Manda uma conta ai que eu calculo!"
    }
    retornar ""
}

